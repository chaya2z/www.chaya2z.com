---
import Layout from "../layouts/Layout.astro";
import ProfileSection from "../components/ProfileSection";
import HeroSection from "../components/HeroSection";
import { ImageLightbox } from "../components/ImageLightbox";
import heroImage from "../assets/images/hero.png";
import expandIcon from "../assets/images/icons/expand.svg";

const links = [
  {
    href: "https://www.linkedin.com/in/chaya2z",
    label: "LinkedIn",
    urlDisplay: "@chaya2z",
  },
  {
    href: "https://github.com/chaya2z",
    label: "GitHub",
    urlDisplay: "@chaya2z",
  },
  {
    href: "https://chaya2z.hatenablog.jp",
    label: "Blog (JP)",
    urlDisplay: "chaya2z.hatenablog.jp",
  },
];
---

<Layout title="chaya2z - Profile">
  <section
    class="relative flex h-225 w-400 overflow-hidden max-2xl:h-screen max-2xl:w-full max-md:flex-col max-md:overflow-y-auto max-md:bg-midnight-bg"
  >
    <ProfileSection links={links} />

    <HeroSection backgroundSrc={heroImage.src}>
      <ImageLightbox
        client:load
        imageSrc={heroImage.src}
        alt="Hero Image"
        caption="This photo of Tokyo Station was taken by me and processed using generative AI."
        className="absolute top-4 right-4 z-20 p-2 bg-black/50 hover:bg-black/70 text-white rounded-full transition-colors cursor-pointer"
        aria-label="Zoom image"
      >
        <img src={expandIcon.src} width="20" height="20" alt="" />
      </ImageLightbox>
    </HeroSection>
  </section>
</Layout>
