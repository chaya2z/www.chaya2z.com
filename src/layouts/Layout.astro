---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --midnight-bg: #1a1b26;
    --ice-blue: #7aa2f7;
    --slate-text: #a9b1d6;
    --accent-red: #8e1d1d;
  }

  body {
    margin: 0;
    padding: 0;
    background-color: #16161e;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    font-family: "Noto Sans JP", sans-serif;
  }
</style>
